# ---- Headcount HQ configuration -------------------------------------------
# On a host, set these as environment variables. Locally (optional), copy to
# .env — the app loads .env automatically if present.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Public address of this server, used to build the Excel "Link to Excel" URL.
# Set this to the address Excel can actually reach. On Render it's your service URL.
# Leave blank only for a purely local run (defaults to http://localhost:PORT).
PUBLIC_URL=https://headcounthq.onrender.com

# Where the SQLite database file lives. On a host, point this at a PERSISTENT
# disk/volume so data survives redeploys (e.g. /data/headcount.sqlite).
DATABASE_PATH=./data/headcount.sqlite

# Secret used to sign session cookies. MUST be a long random string in
# production — generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The app refuses to boot in production with the placeholder value.
SESSION_SECRET=dev-only-insecure-change-me-please-0000000000000000

# Cookie Secure flag. MUST match how you access the app:
#   - Running locally over http://localhost  -> false  (browsers drop Secure cookies on http,
#     which would make every form fail with "Invalid CSRF token")
#   - Served over HTTPS (production)          -> true   (render.yaml sets this for you)
COOKIE_SECURE=false

# ---- Optional: email invites (SMTP). Leave SMTP_HOST empty to disable email
# invites — the admin can still create accounts with a temporary password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Headcount HQ <no-reply@example.com>

# ---- Optional: AI-assisted roster import -----------------------------------
# Off unless a key is set here AND the toggle is enabled on the Philosophy page.
# Only column headers, department names, and job titles are ever sent to the
# provider — never salaries, employee names, or any row of data.
#
# Provider options:
#   gemini     -> Google Gemini. FREE TIER available — get a key at
#                 https://aistudio.google.com/apikey  (no credit card)
#   anthropic  -> Claude (pay-per-use)
#   openai     -> OpenAI (pay-per-use), or any OpenAI-compatible host via AI_IMPORT_BASE_URL
#
# Easiest free setup (Google Gemini):
#   AI_IMPORT_PROVIDER=gemini
#   AI_IMPORT_API_KEY=your-free-gemini-key
#
AI_IMPORT_PROVIDER=
AI_IMPORT_API_KEY=
# Optional — override the default model (defaults: gemini-2.5-flash / gpt-4o-mini / claude-haiku-4-5)
AI_IMPORT_MODEL=
# Optional — only for other OpenAI-compatible hosts (e.g. Groq: https://api.groq.com/openai/v1)
AI_IMPORT_BASE_URL=
